# Copy to .env and restart the server.

# --- Local development ---
# APP_URL=http://localhost:5173

# --- Vercel (frontend only) + Railway/Render (API) ---
# On Vercel → Environment Variables:
#   VITE_API_URL=https://YOUR-APP.up.railway.app
#
# On Railway/Render (API server):
#   API_URL=https://pdfgerage-production.up.railway.app
#   FRONTEND_URL=https://pdfgerage.com
#   APP_URL=https://pdfgerage.com
#   CLIENT_ORIGIN=https://pdfgerage.com,https://www.pdfgerage.com,https://pdfgerage.vercel.app
#   JWT_SECRET=long-random-string
#
# --- Production (single server — Railway/Render/VPS) ---
APP_URL=https://pdfgerage.com
NODE_ENV=production
PORT=8080

JWT_SECRET=change-this-to-a-long-random-string

# Google Sign-In (required for "Continue with Google" on login/signup)
# https://console.cloud.google.com/apis/credentials → OAuth Client ID → Web application
#
# Local dev:
#   Origins:  http://localhost:5173
#   Redirect: http://localhost:5173/api/auth/google/callback
#
# Production (pdfgerage.com):
#   Origins:  https://pdfgerage.com
#             https://www.pdfgerage.com   (if you use www)
#   Redirect: https://pdfgerage.com/api/auth/google/callback
#             https://www.pdfgerage.com/api/auth/google/callback   (if you use www)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional — Google Drive file picker only (not used for sign-in)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# Optional cloud import
VITE_DROPBOX_APP_KEY=
VITE_ONEDRIVE_CLIENT_ID=

# Optional support email shown on Contact page
CONTACT_EMAIL=support@pdfgerage.app

# Translation providers (comma-separated, first available wins)
# google = free fallback (default primary), mymemory = needs quota, libretranslate = local Docker
# TRANSLATE_PROVIDERS=google,mymemory,libretranslate

# MyMemory — optional email for higher free quota (~50k chars/day)
# https://mymemory.translated.net/doc/usagelimits.php
MYMEMORY_EMAIL=

# Optional self-hosted LibreTranslate (docker run -p 5000:5000 libretranslate/libretranslate)
# LIBRETRANSLATE_URL=http://127.0.0.1:5000
# LIBRETRANSLATE_API_KEY=

# Milliseconds between translation API calls (default 350)
# TRANSLATE_REQUEST_INTERVAL_MS=350
