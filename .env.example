# Copy to .env and restart the server.

# --- Local development ---
# APP_URL=http://localhost:5173

# --- Vercel (frontend only) + Railway/Render (API) ---
# On Vercel → Environment Variables:
#   VITE_API_URL=https://YOUR-APP.up.railway.app
#
# On Railway/Render (API server):
#   API_URL=https://pdfgerage-production.up.railway.app
#   FRONTEND_URL=https://pdfgerage.com
#   APP_URL=https://pdfgerage.com
#   CLIENT_ORIGIN=https://pdfgerage.com,https://www.pdfgerage.com,https://pdfgerage.vercel.app
#   JWT_SECRET=long-random-string
#
# --- Production (single server — Railway/Render/VPS) ---
APP_URL=https://pdfgerage.com
NODE_ENV=production
PORT=8080

# --- Payments: credit card + bank transfer + Wise ---
# Stripe is NOT available in Pakistan. Use the three options below.
#
# 1) CREDIT / DEBIT CARD (auto — credits added instantly)
# Sign up at https://lemonsqueezy.com (payouts to Wise / Payoneer / Pakistani bank)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_PACKAGE=
LEMONSQUEEZY_VARIANT_SUBSCRIPTION=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Webhook: https://YOUR-API.up.railway.app/api/billing/webhook  event: order_created
#
# 2) BANK TRANSFER (manual — you approve credits after payment)
MANUAL_PAYMENT_BANK_NAME=Your Bank Name
MANUAL_PAYMENT_BANK_ACCOUNT=Account number or details
MANUAL_PAYMENT_BANK_HOLDER=Account holder name
MANUAL_PAYMENT_BANK_IBAN=
MANUAL_PAYMENT_BANK_SWIFT=
MANUAL_PAYMENT_BANK_NOTE=Send USD via bank transfer and include your order reference.
#
# 3) WISE (manual — you approve credits after payment)
# Your Wise email, payment link (wise.com/pay/me/...), or account details
MANUAL_PAYMENT_WISE=
MANUAL_PAYMENT_WISE_NOTE=
#
MANUAL_PAYMENT_NOTE=Always include your order reference (e.g. PG-XXXXXXXX) in the payment description.
#
# After bank/Wise payment, approve credits:
# curl -X POST https://YOUR-API/api/billing/admin/fulfill \
#   -H "X-Admin-Secret: YOUR_SECRET" -H "Content-Type: application/json" \
#   -d '{"orderId":"PG-XXXXXXXX"}'
ADMIN_BILLING_SECRET=

# Conversion speed (optional — defaults are tuned for fast processing)
# PDF_RENDER_DPI=200
# PDF_PAGE_CONCURRENCY=4
# CONVERT_BATCH_CONCURRENCY=3
# ZIP_COMPRESSION_LEVEL=1
# OCR — accuracy mode is default (multi-pass, 288 DPI PDFs, 3 engines)
# OCR_FAST=true          # faster, lower accuracy (~216 DPI, fewer passes)
# OCR_PDF_SCALE=4        # PDF render scale (4 ≈ 288 DPI, 5 ≈ 360 DPI)

JWT_SECRET=change-this-to-a-long-random-string

# Google Sign-In (required for "Continue with Google" on login/signup)
# https://console.cloud.google.com/apis/credentials → OAuth Client ID → Web application
#
# Local dev:
#   Origins:  http://localhost:5173
#   Redirect: http://localhost:5173/api/auth/google/callback
#
# Production (pdfgerage.com):
#   Origins:  https://pdfgerage.com
#             https://www.pdfgerage.com   (if you use www)
#   Redirect: https://pdfgerage.com/api/auth/google/callback
#             https://www.pdfgerage.com/api/auth/google/callback   (if you use www)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional — Google Drive file picker only (not used for sign-in)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# Optional cloud import
VITE_DROPBOX_APP_KEY=
VITE_ONEDRIVE_CLIENT_ID=

# Optional support email shown on Contact page
CONTACT_EMAIL=support@pdfgerage.app

# Translation providers (comma-separated, first available wins)
# google = free fallback (default primary), mymemory = needs quota, libretranslate = local Docker
# TRANSLATE_PROVIDERS=google,mymemory,libretranslate

# MyMemory — optional email for higher free quota (~50k chars/day)
# https://mymemory.translated.net/doc/usagelimits.php
MYMEMORY_EMAIL=

# Optional self-hosted LibreTranslate (docker run -p 5000:5000 libretranslate/libretranslate)
# LIBRETRANSLATE_URL=http://127.0.0.1:5000
# LIBRETRANSLATE_API_KEY=

# Milliseconds between translation API calls (default 350)
# TRANSLATE_REQUEST_INTERVAL_MS=350

# Chat with PDF AI (OpenAI-compatible or Google Gemini — set at least one)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
