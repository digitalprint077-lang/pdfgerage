{
  "name": "pdfgerage",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "build:prod": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "start:prod": "npm run build:prod && node server/index.js",
    "test:translate": "node server/testTranslate.js",
    "setup:python": "pip install -r server/requirements.txt"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "country-flag-icons": "^1.6.19",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "franc-min": "^6.2.0",
    "google-translate-api-x": "^10.7.3",
    "jsonwebtoken": "^9.0.3",
    "libreoffice-convert": "^1.6.1",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdf-to-img": "^4.4.0",
    "pdfkit": "^0.16.0",
    "pptxgenjs": "^4.0.1",
    "react-router-dom": "^7.18.0",
    "sharp": "^0.33.5",
    "tesseract.js": "^7.0.0",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
